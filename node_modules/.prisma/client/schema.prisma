generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id           Int       @id @default(autoincrement())
  slug         String    @unique
  title        String
  excerpt      String
  content      String    @default("")
  category     String    @default("Журнал")
  categorySlug String    @default("hair-care")
  coverImage   String    @default("/site/img/blog/blog-hero.png")
  readingTime  String    @default("3 мин")
  isPublished  Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isPublished])
  @@index([categorySlug])
  @@index([publishedAt])
}

model Work {
  id   Int    @id @default(autoincrement())
  slug String @unique

  title   String
  excerpt String @default("")

  category     String @default("Работа")
  categorySlug String @default("airtouch")

  beforeImage String
  afterImage  String

  technique String @default("")
  duration  String @default("")

  isPublished Boolean @default(false)
  showOnHome  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished])
  @@index([showOnHome])
  @@index([categorySlug])
}
